-- ====================== ESP PROFISSIONAL ======================
local ESPObjects = {}
local function CreateESP(plr)
    if plr == player then return end
    local box = Drawing.new("Square"); box.Thickness = 2.2; box.Color = Color3.fromRGB(0, 170, 255); box.Transparency = 1
    local name = Drawing.new("Text"); name.Size = 16; name.Color = Color3.new(1,1,1); name.Center = true; name.Outline = true
    local tracer = Drawing.new("Line"); tracer.Thickness = 1.6; tracer.Color = Color3.fromRGB(0, 200, 255); tracer.Transparency = 0.75
    
    ESPObjects[plr] = {Box = box, Name = name, Tracer = tracer}

    RunService.RenderStepped:Connect(function()
        local character = plr.Character
        if not character or not character:FindFirstChild("HumanoidRootPart") then
            box.Visible = false; name.Visible = false; tracer.Visible = false
            return
        end

        local rootPart = character.HumanoidRootPart
        local head = character:FindFirstChild("Head")
        local rootPos, onScreen = camera:WorldToViewportPoint(rootPart.Position)

        if onScreen then
            if Vars.BoxESP then
                local headPos = camera:WorldToViewportPoint(head.Position)
                local legPos = camera:WorldToViewportPoint(rootPart.Position - Vector3.new(0, 3.4, 0))
                box.Size = Vector2.new((headPos.Y - legPos.Y) * 0.52, headPos.Y - legPos.Y)
                box.Position = Vector2.new(rootPos.X - box.Size.X/2, rootPos.Y - box.Size.Y * 0.48)
                box.Visible = true
            else box.Visible = false end

            if Vars.NameESP then
                name.Text = plr.DisplayName .. " [" .. math.floor((root.Position - rootPart.Position).Magnitude) .. "m]"
                name.Position = Vector2.new(rootPos.X, rootPos.Y - 40)
                name.Visible = true
            else name.Visible = false end

            if Vars.Tracers then
                tracer.From = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y - 50)
                tracer.To = Vector2.new(rootPos.X, rootPos.Y)
                tracer.Visible = true
            else tracer.Visible = false end
        else
            box.Visible = false; name.Visible = false; tracer.Visible = false
        end
    end)
end

for _, plr in ipairs(Players:GetPlayers()) do CreateESP(plr) end
Players.PlayerAdded:Connect(CreateESP)


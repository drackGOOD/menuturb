-- ====================== FEATURES LOGIC ======================

-- Click Teleport
mouse.Button1Down:Connect(function()
    if Vars.ClickTeleport and UIS:IsKeyDown(Enum.KeyCode.LeftAlt) and root then
        root.CFrame = CFrame.new(mouse.Hit.Position + Vector3.new(0, 5, 0))
    end
end)

-- Aimbot
RunService.RenderStepped:Connect(function()
    if Vars.Aimbot and UIS:IsMouseButtonPressed(Vars.AimbotKey) then
        local closest = nil
        local minDist = Vars.AimbotFOV
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild("Head") then
                local pos, onScreen = camera:WorldToViewportPoint(p.Character.Head.Position)
                if onScreen then
                    local dist = (Vector2.new(pos.X, pos.Y) - Vector2.new(mouse.X, mouse.Y)).Magnitude
                    if dist < minDist then minDist = dist; closest = p.Character.Head end
                end
            end
        end
        if closest then
            camera.CFrame = camera.CFrame:Lerp(CFrame.lookAt(camera.CFrame.Position, closest.Position), Vars.AimbotSmoothness)
        end
    end
end)

-- Fly Logic
local bv, bg = nil, nil
RunService.Stepped:Connect(function()
    if Vars.Fly and root then
        if not bv then
            bv = Instance.new("BodyVelocity", root); bv.MaxForce = Vector3.new(1e5, 1e5, 1e5)
            bg = Instance.new("BodyGyro", root); bg.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
        end
        local move = Vector3.new()
        if UIS:IsKeyDown(Enum.KeyCode.W) then move += camera.CFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.S) then move -= camera.CFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.A) then move -= camera.CFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.D) then move += camera.CFrame.RightVector end
        bv.Velocity = move.Unit * 100
        bg.CFrame = camera.CFrame
        for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false end end
    elseif bv then
        bv:Destroy(); bv = nil; bg:Destroy(); bg = nil
        for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = true end end
    end
end)

-- Speed e Jump
RunService.Heartbeat:Connect(function()
    if hum then hum.WalkSpeed = Vars.SpeedHack and Vars.SpeedValue or 16 end
end)
UIS.JumpRequest:Connect(function()
    if Vars.InfiniteJump and hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
end)

-- Atalhos Teclado
UIS.InputBegan:Connect(function(i, gp)
    if gp then return end
    if i.KeyCode == Enum.KeyCode.K then Main.Visible = not Main.Visible end
    if i.KeyCode == Enum.KeyCode.V then Vars.Fly = not Vars.Fly end
end)


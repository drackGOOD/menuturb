--[[
    PRO MULTI-TOOL V5 (ULTIMATE EDITION)
    - Noclip (Atravessa Paredes)
    - Autoclick (Rápido e Seguro)
    - Fly & God & ESP & TP
    - Atalho: [K] para abrir/fechar
]]

local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local player = Players.LocalPlayer
local mouse = player:GetMouse()
local camera = workspace.CurrentCamera

--// ESTADOS DO SCRIPT
local Vars = {
    Fly = false,
    God = false,
    Noclip = false,
    Autoclick = false,
    ESP = true,
    Speed = 80,
    PanelOpen = true
}

--// PERSONAGEM
local char, root, hum
local function SetupChar(c)
    char = c
    root = c:WaitForChild("HumanoidRootPart")
    hum = c:WaitForChild("Humanoid")
end
player.CharacterAdded:Connect(SetupChar)
if player.Character then SetupChar(player.Character) end

--// INTERFACE POLIDA
local ScreenGui = Instance.new("ScreenGui", player.PlayerGui)
ScreenGui.ResetOnSpawn = false

local Main = Instance.new("Frame", ScreenGui)
Main.Size = UDim2.new(0, 260, 0, 400)
Main.Position = UDim2.new(0.5, -130, 0.5, -200)
Main.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
Main.BorderSizePixel = 0
Main.ClipsDescendants = true
Main.Active = true
Main.Draggable = true

local UICorner = Instance.new("UICorner", Main)
UICorner.CornerRadius = UDim.new(0, 12)

local Title = Instance.new("TextLabel", Main)
Title.Size = UDim2.new(1, 0, 0, 50)
Title.Text = "PREMIUM HUB V5"
Title.TextColor3 = Color3.new(1, 1, 1)
Title.Font = Enum.Font.GothamBold
Title.TextSize = 18
Title.BackgroundTransparency = 1

local Container = Instance.new("ScrollingFrame", Main)
Container.Size = UDim2.new(0.9, 0, 0.8, 0)
Container.Position = UDim2.new(0.05, 0, 0.15, 0)
Container.BackgroundTransparency = 1
Container.CanvasSize = UDim2.new(0, 0, 1.5, 0)
Container.ScrollBarThickness = 0

local Layout = Instance.new("UIListLayout", Container)
Layout.Padding = UDim.new(0, 8)

--// FUNÇÃO DE BOTÃO POLIDO
local function CreateToggle(name, varName, callback)
    local Btn = Instance.new("TextButton", Container)
    Btn.Size = UDim2.new(1, 0, 0, 40)
    Btn.BackgroundColor3 = Vars[varName] and Color3.fromRGB(60, 180, 110) or Color3.fromRGB(45, 45, 50)
    Btn.Text = name
    Btn.TextColor3 = Color3.new(1, 1, 1)
    Btn.Font = Enum.Font.GothamMedium
    Btn.AutoButtonColor = false
    
    local Corner = Instance.new("UICorner", Btn)
    
    Btn.MouseButton1Click:Connect(function()
        Vars[varName] = not Vars[varName]
        -- Efeito visual de clique
        Btn.BackgroundColor3 = Vars[varName] and Color3.fromRGB(60, 180, 110) or Color3.fromRGB(45, 45, 50)
        if callback then callback(Vars[varName]) end
    end)
end

--// FUNÇÕES
-- VOO
local bv, bg
CreateToggle("VOAR (V)", "Fly", function(state)
    if state then
        bv = Instance.new("BodyVelocity", root)
        bg = Instance.new("BodyGyro", root)
        bv.MaxForce = Vector3.new(1e6, 1e6, 1e6)
        bg.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
    else
        if bv then bv:Destroy() end
        if bg then bg:Destroy() end
    end
end)

-- NOCLIP (ATRAVESSAR TUDO)
CreateToggle("ATRAVESSAR (N)", "Noclip")

-- AUTOCLICK
CreateToggle("AUTOCLICK", "Autoclick")

-- GOD MODE
CreateToggle("CURA INFINITA", "God")

-- ESP
CreateToggle("MOSTRAR PLAYERS", "ESP")

--// LOOPS DE FUNCIONAMENTO
local move = {f=0, b=0, l=0, r=0, u=0, d=0}

RunService.Stepped:Connect(function()
    -- Lógica do Noclip (Atravessar)
    if Vars.Noclip and char then
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end
    
    -- Lógica do God
    if Vars.God and hum then hum.Health = hum.MaxHealth end
    
    -- Lógica do Fly
    if Vars.Fly and root and bv and bg then
        bg.CFrame = camera.CFrame
        local dir = camera.CFrame.LookVector * (move.f + move.b) + camera.CFrame.RightVector * (move.l + move.r) + camera.CFrame.UpVector * (move.u + move.d)
        bv.Velocity = dir * Vars.Speed
    end
end)

-- Lógica Autoclick (Rápido)
task.spawn(function()
    while true do
        if Vars.Autoclick then
            mouse1click() -- Executa o clique do mouse
        end
        task.wait(0.01) -- Velocidade do clique
    end
end)

--// INPUTS
UIS.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    
    if input.KeyCode == Enum.KeyCode.K then 
        Vars.PanelOpen = not Vars.PanelOpen
        Main.Visible = Vars.PanelOpen
    end
    
    -- Teclas de Voo
    if input.KeyCode == Enum.KeyCode.W then move.f = 1 end
    if input.KeyCode == Enum.KeyCode.S then move.b = -1 end
    if input.KeyCode == Enum.KeyCode.A then move.l = -1 end
    if input.KeyCode == Enum.KeyCode.D then move.r = 1 end
    if input.KeyCode == Enum.KeyCode.Space then move.u = 1 end
    if input.KeyCode == Enum.KeyCode.LeftShift then move.d = -1 end
end)

UIS.InputEnded:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.W then move.f = 0 end
    if input.KeyCode == Enum.KeyCode.S then move.b = 0 end
    if input.KeyCode == Enum.KeyCode.A then move.l = 0 end
    if input.KeyCode == Enum.KeyCode.D then move.r = 0 end
    if input.KeyCode == Enum.KeyCode.Space then move.u = 0 end
    if input.KeyCode == Enum.KeyCode.LeftShift then move.d = 0 end
end)

-- Teleporte Alt+Click
mouse.Button1Down:Connect(function()
    if UIS:IsKeyDown(Enum.KeyCode.LeftAlt) then
        root.CFrame = CFrame.new(mouse.Hit.Position + Vector3.new(0, 3, 0))
    end
end)

print("Script V5 Polido Carregado! Use 'K' para o menu.")

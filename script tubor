-- Aimbot (mais suave)
RunService.RenderStepped:Connect(function()
    if Vars.Aimbot and UIS:IsMouseButtonPressed(Vars.AimbotKey) then
        local target = nil
        local closest = math.huge

        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild("Head") then
                local head = p.Character.Head
                local screenPos, onScreen = camera:WorldToViewportPoint(head.Position)
                if onScreen then
                    local dist = (Vector2.new(screenPos.X, screenPos.Y) - Vector2.new(mouse.X, mouse.Y)).Magnitude
                    if dist < closest and dist < 450 then
                        closest = dist
                        target = head
                    end
                end
            end
        end

        if target then
            camera.CFrame = CFrame.lookAt(camera.CFrame.Position, target.Position)
        end
    end
end)

-- Fly + Noclip
local bodyVelocity = nil
local bodyGyro = nil

RunService.Stepped:Connect(function()
    if Vars.Fly and root then
        if not bodyVelocity then
            bodyVelocity = Instance.new("BodyVelocity")
            bodyVelocity.MaxForce = Vector3.new(1e5, 1e5, 1e5)
            bodyVelocity.Parent = root
        end
        if not bodyGyro then
            bodyGyro = Instance.new("BodyGyro")
            bodyGyro.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
            bodyGyro.Parent = root
        end

        local camLook = camera.CFrame.LookVector
        local move = Vector3.new()

        if UIS:IsKeyDown(Enum.KeyCode.W) then move += camLook end
        if UIS:IsKeyDown(Enum.KeyCode.S) then move -= camLook end
        if UIS:IsKeyDown(Enum.KeyCode.A) then move -= camera.CFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.D) then move += camera.CFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.Space) then move += Vector3.new(0,1,0) end
        if UIS:IsKeyDown(Enum.KeyCode.LeftControl) then move -= Vector3.new(0,1,0) end

        bodyVelocity.Velocity = move.Unit * 80
        bodyGyro.CFrame = camera.CFrame
    elseif bodyVelocity then
        bodyVelocity:Destroy()
        bodyVelocity = nil
        bodyGyro:Destroy()
        bodyGyro = nil
    end

    -- Noclip
    if (Vars.Fly or Vars.Noclip) and char then
        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") and v.CanCollide then
                v.CanCollide = false
            end
        end
    end
end)


-- Função para Criar Botão estilo GTA
local function AddOption(name, varName)
    local Btn = Instance.new("TextButton")
    Btn.Size = UDim2.new(1, 0, 0, 35)
    Btn.BackgroundColor3 = Color3.new(0, 0, 0)
    Btn.BackgroundTransparency = 0.5
    Btn.BorderSizePixel = 0
    Btn.Text = "  " .. name
    Btn.TextColor3 = Color3.new(1, 1, 1)
    Btn.Font = Enum.Font.SourceSans
    Btn.TextSize = 18
    Btn.TextXAlignment = Enum.TextXAlignment.Left
    Btn.AutoButtonColor = false
    Btn.Parent = Scroll

    local Indicator = Instance.new("Frame")
    Indicator.Size = UDim2.new(0, 5, 1, 0)
    Indicator.Position = UDim2.new(1, -5, 0, 0)
    Indicator.BackgroundColor3 = Color3.new(1, 0, 0) -- Vermelho OFF
    Indicator.BorderSizePixel = 0
    Indicator.Parent = Btn

    Btn.MouseButton1Click:Connect(function()
        Vars[varName] = not Vars[varName]
        Indicator.BackgroundColor3 = Vars[varName] and Color3.new(0, 1, 0) or Color3.new(1, 0, 0)
        
        -- Feedback visual de clique
        Btn.BackgroundColor3 = Color3.new(1, 1, 1)
        Btn.TextColor3 = Color3.new(0, 0, 0)
        task.wait(0.1)
        Btn.BackgroundColor3 = Color3.new(0, 0, 0)
        Btn.TextColor3 = Color3.new(1, 1, 1)
    end)
end


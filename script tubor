--// SISTEMA DE TP E BRING
local function UpdateList()
    for _, v in pairs(Container:GetChildren()) do if v.Name == "PFrame" then v:Destroy() end end
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player then
            local pf = Instance.new("Frame", Container)
            pf.Name = "PFrame"
            pf.Size = UDim2.new(1, 0, 0, 50)
            pf.BackgroundTransparency = 1

            local tp = Instance.new("TextButton", pf)
            tp.Size = UDim2.new(0.48, 0, 1, 0)
            tp.Text = "IR: "..p.DisplayName
            tp.BackgroundColor3 = Color3.fromRGB(30, 50, 30)
            tp.TextColor3 = Color3.new(1,1,1)
            Instance.new("UICorner", tp)

            local bring = Instance.new("TextButton", pf)
            bring.Size = UDim2.new(0.48, 0, 1, 0)
            bring.Position = UDim2.new(0.52, 0, 0, 0)
            bring.Text = "PUXAR"
            bring.BackgroundColor3 = Color3.fromRGB(60, 30, 30)
            bring.TextColor3 = Color3.new(1,1,1)
            Instance.new("UICorner", bring)

            tp.MouseButton1Click:Connect(function()
                root.CFrame = p.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3)
            end)

            bring.MouseButton1Click:Connect(function()
                if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    p.Character.HumanoidRootPart.CFrame = root.CFrame * CFrame.new(0, 0, -3)
                end
            end)
        end
    end
end

--// LOOPS DE EXECUÇÃO
local flyVec = {f=0, b=0, l=0, r=0, u=0, d=0}

RunService.RenderStepped:Connect(function()
    -- Aimbot
    if Vars.Aimbot then
        local t = GetClosest()
        if t then camera.CFrame = CFrame.new(camera.CFrame.Position, t.Position) end
    end
    -- God
    if Vars.God and hum then hum.Health = hum.MaxHealth end
    -- Noclip
    if Vars.Noclip and char then
        for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false end end
    end
    -- Fly
    if Vars.Fly and root then
        local dir = camera.CFrame.LookVector * (flyVec.f + flyVec.b) + camera.CFrame.RightVector * (flyVec.l + flyVec.r) + camera.CFrame.UpVector * (flyVec.u + flyVec.d)
        root.Velocity = dir * Vars.Speed
        root.Anchored = (dir.Magnitude == 0) -- Evita cair quando parado
    else
        root.Anchored = false
    end
end)

-- Autoclick Thread
task.spawn(function()
    while true do
        if Vars.Autoclick then
            if mouse1click then mouse1click() end
        end
        task.wait(0.01)
    end
end)

--// INPUTS
UIS.InputBegan:Connect(function(i, g)
    if g then return end
    if i.KeyCode == Vars.PanelKey then Main.Visible = not Main.Visible end
    if i.KeyCode == Enum.KeyCode.W then flyVec.f = 1 end
    if i.KeyCode == Enum.KeyCode.S then flyVec.b = -1 end
    if i.KeyCode == Enum.KeyCode.A then flyVec.l = -1 end
    if i.KeyCode == Enum.KeyCode.D then flyVec.r = 1 end
    if i.KeyCode == Enum.KeyCode.Space then flyVec.u = 1 end
    if i.KeyCode == Enum.KeyCode.LeftControl then flyVec.d = -1 end
end)

UIS.InputEnded:Connect(function(i)
    if i.KeyCode == Enum.KeyCode.W then flyVec.f = 0 end
    if i.KeyCode == Enum.KeyCode.S then flyVec.b = 0 end
    if i.KeyCode == Enum.KeyCode.A then flyVec.l = 0 end
    if i.KeyCode == Enum.KeyCode.D then flyVec.r = 0 end
    if i.KeyCode == Enum.KeyCode.Space then flyVec.u = 0 end
    if i.KeyCode == Enum.KeyCode.LeftControl then flyVec.d = 0 end
end)

-- Alt + Click Teleport
mouse.Button1Down:Connect(function()
    if UIS:IsKeyDown(Enum.KeyCode.LeftAlt) then
        root.CFrame = CFrame.new(mouse.Hit.p + Vector3.new(0, 3, 0))
    end
end)

-- Update Player List
task.spawn(function()
    while true do UpdateList(); task.wait(5) end
end)

print("ELITE SUPREMO V8 ATIVADO!")

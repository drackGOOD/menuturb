    Indicator.Size = UDim2.new(0, 6, 0, 28)
    Indicator.Position = UDim2.new(1, -18, 0.5, -14)
    Indicator.BackgroundColor3 = Color3.fromRGB(200, 55, 55) -- Vermelho OFF

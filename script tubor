-- ====================== FUNÇÃO DE TOGGLE PREMIUM ======================
local function CreateToggle(text, varName, callback)
    local Toggle = Instance.new("TextButton")
    Toggle.Size = UDim2.new(1, 0, 0, 50)
    Toggle.BackgroundColor3 = Color3.fromRGB(28, 28, 38)
    Toggle.Text = "   " .. text
    Toggle.TextColor3 = Color3.fromRGB(200, 200, 200)
    Toggle.TextXAlignment = Enum.TextXAlignment.Left
    Toggle.Font = Enum.Font.GothamMedium
    Toggle.TextSize = 15
    Toggle.Parent = Container

    local Corner = Instance.new("UICorner", Toggle)
    Corner.CornerRadius = UDim.new(0, 12)

    local Indicator = Instance.new("Frame")
    Indicator.Size = UDim2.new(0, 18, 0, 18)
    Indicator.Position = UDim2.new(1, -30, 0.5, -9)
    Indicator.BackgroundColor3 = Color3.fromRGB(60, 60, 70)
    Indicator.Parent = Toggle

    local IndCorner = Instance.new("UICorner", Indicator)
    IndCorner.CornerRadius = UDim.new(1, 0)

    Toggle.MouseButton1Click:Connect(function()
        Vars[varName] = not Vars[varName]
        local active = Vars[varName]

        TweenService:Create(Toggle, TweenInfo.new(0.25, Enum.EasingStyle.Quint), {
            BackgroundColor3 = active and Color3.fromRGB(50, 70, 160) or Color3.fromRGB(28, 28, 38)
        }):Play()

        TweenService:Create(Indicator, TweenInfo.new(0.25, Enum.EasingStyle.Quint), {
            BackgroundColor3 = active and Color3.fromRGB(80, 200, 120) or Color3.fromRGB(60, 60, 70)
        }):Play()

        if callback then callback(active) end
    end)
end


--[[
    ALL-IN-ONE PRO V4 (REMASTERED)
    Atalhos:
    [K] - Abrir/Fechar Menu
    [ALT + Clique] - Teleporte para o Mouse
    [Espaço/Shift] - Subir/Descer no Voo
]]

local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local player = Players.LocalPlayer
local camera = workspace.CurrentCamera
local mouse = player:GetMouse()

-- Vars de Estado
local _G = {
    Fly = false,
    God = false,
    ESP = true,
    Speed = 80,
    PanelVisible = true
}

-- Sincronização de Personagem
local char = player.Character or player.CharacterAdded:Wait()
local root = char:WaitForChild("HumanoidRootPart")
local hum = char:WaitForChild("Humanoid")

player.CharacterAdded:Connect(function(newChar)
    char = newChar
    root = newChar:WaitForChild("HumanoidRootPart")
    hum = newChar:WaitForChild("Humanoid")
end)

-- UI PRINCIPAL
local ScreenGui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))
ScreenGui.ResetOnSpawn = false

local Main = Instance.new("Frame", ScreenGui)
Main.Size = UDim2.new(0, 250, 0, 380)
Main.Position = UDim2.new(0.05, 0, 0.4, 0)
Main.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
Main.BorderSizePixel = 0
Main.Active = true
Main.Draggable = true -- Permite arrastar o painel

local Corner = Instance.new("UICorner", Main)
local Title = Instance.new("TextLabel", Main)
Title.Size = UDim2.new(1, 0, 0, 40)
Title.Text = "PREMIUM PANEL V4"
Title.TextColor3 = Color3.new(1, 1, 1)
Title.Font = Enum.Font.GothamBold
Title.BackgroundTransparency = 1

local Scroll = Instance.new("ScrollingFrame", Main)
Scroll.Size = UDim2.new(0.9, 0, 0.8, 0)
Scroll.Position = UDim2.new(0.05, 0, 0.15, 0)
Scroll.BackgroundTransparency = 1
Scroll.CanvasSize = UDim2.new(0, 0, 2, 0)
Scroll.ScrollBarThickness = 2

local Layout = Instance.new("UIListLayout", Scroll)
Layout.Padding = UDim.new(0, 5)

-- FUNÇÃO PARA BOTÕES
local function createToggle(name, default, callback)
    local btn = Instance.new("TextButton", Scroll)
    btn.Size = UDim2.new(1, 0, 0, 35)
    btn.BackgroundColor3 = default and Color3.fromRGB(40, 100, 40) or Color3.fromRGB(40, 40, 45)
    btn.Text = name .. ": " .. (default and "ON" or "OFF")
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.Gotham
    Instance.new("UICorner", btn)

    local state = default
    btn.MouseButton1Click:Connect(function()
        state = not state
        btn.Text = name .. ": " .. (state and "ON" or "OFF")
        btn.BackgroundColor3 = state and Color3.fromRGB(40, 100, 40) or Color3.fromRGB(40, 40, 45)
        callback(state)
    end)
end

-- SISTEMA DE VOO (ESTÁVEL)
local bv, bg
createToggle("VOAR", false, function(t)
    _G.Fly = t
    if t then
        bv = Instance.new("BodyVelocity", root)
        bg = Instance.new("BodyGyro", root)
        bv.MaxForce = Vector3.new(1e6, 1e6, 1e6)
        bg.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
    else
        if bv then bv:Destroy() end
        if bg then bg:Destroy() end
    end
end)

createToggle("GOD MODE", false, function(t) _G.God = t end)
createToggle("ESP", true, function(t) _G.ESP = t end)

-- SEÇÃO DE TELEPORTE
local Label = Instance.new("TextLabel", Scroll)
Label.Size = UDim2.new(1, 0, 0, 20)
Label.Text = "--- JOGADORES ---"
Label.BackgroundTransparency = 1
Label.TextColor3 = Color3.new(0.6, 0.6, 0.6)

local function updateTPList()
    for _, v in pairs(Scroll:GetChildren()) do
        if v.Name == "TPBtn" then v:Destroy() end
    end
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player then
            local b = Instance.new("TextButton", Scroll)
            b.Name = "TPBtn"
            b.Size = UDim2.new(1, 0, 0, 30)
            b.Text = "IR ATÉ: " .. p.DisplayName
            b.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
            b.TextColor3 = Color3.new(0.8, 0.8, 0.8)
            Instance.new("UICorner", b)
            b.MouseButton1Click:Connect(function()
                if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    root.CFrame = p.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, -3)
                end
            end)
        end
    end
end

-- CONTROLES DE VOO
local move = {f=0, b=0, l=0, r=0, u=0, d=0}
UIS.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.K then Main.Visible = not Main.Visible end
    if input.KeyCode == Enum.KeyCode.W then move.f = 1 end
    if input.KeyCode == Enum.KeyCode.S then move.b = -1 end
    if input.KeyCode == Enum.KeyCode.A then move.l = -1 end
    if input.KeyCode == Enum.KeyCode.D then move.r = 1 end
    if input.KeyCode == Enum.KeyCode.Space then move.u = 1 end
    if input.KeyCode == Enum.KeyCode.LeftShift then move.d = -1 end
end)

UIS.InputEnded:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.W then move.f = 0 end
    if input.KeyCode == Enum.KeyCode.S then move.b = 0 end
    if input.KeyCode == Enum.KeyCode.A then move.l = 0 end
    if input.KeyCode == Enum.KeyCode.D then move.r = 0 end
    if input.KeyCode == Enum.KeyCode.Space then move.u = 0 end
    if input.KeyCode == Enum.KeyCode.LeftShift then move.d = 0 end
end)

-- CLICK TP
mouse.Button1Down:Connect(function()
    if UIS:IsKeyDown(Enum.KeyCode.LeftAlt) then
        root.CFrame = CFrame.new(mouse.Hit.Position + Vector3.new(0, 3, 0))
    end
end)

-- LOOP PRINCIPAL
RunService.RenderStepped:Connect(function()
    if _G.God and hum then hum.Health = hum.MaxHealth end
    
    if _G.Fly and root and bv and bg then
        bg.CFrame = camera.CFrame
        local comb = camera.CFrame.LookVector * (move.f + move.b) + camera.CFrame.RightVector * (move.l + move.r) + camera.CFrame.UpVector * (move.u + move.d)
        bv.Velocity = comb * _G.Speed
    end
end)

-- ATUALIZADOR DE LISTA
task.spawn(function()
    while true do
        updateTPList()
        task.wait(5)
    end
end)

print("Painel Carregado com Sucesso!")

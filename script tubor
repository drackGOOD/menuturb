--// LISTA DE PLAYERS (BRING/TP)
local pLabel = Instance.new("TextLabel", Container)
pLabel.Size = UDim2.new(1, 0, 0, 30); pLabel.Text = "JOGADORES"; pLabel.TextColor3 = Color3.new(0.4, 0.4, 0.4); pLabel.BackgroundTransparency = 1

local function UpdateList()
    for _, v in pairs(Container:GetChildren()) do if v.Name == "P" then v:Destroy() end end
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player then
            local f = Instance.new("Frame", Container); f.Name = "P"; f.Size = UDim2.new(1, 0, 0, 40); f.BackgroundTransparency = 1
            local tp = Instance.new("TextButton", f); tp.Size = UDim2.new(0.48, 0, 1, 0); tp.Text = "IR: "..p.DisplayName; tp.BackgroundColor3 = Color3.fromRGB(40, 50, 40); tp.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", tp)
            local br = Instance.new("TextButton", f); br.Size = UDim2.new(0.48, 0, 1, 0); br.Position = UDim2.new(0.52, 0, 0, 0); br.Text = "PUXAR"; br.BackgroundColor3 = Color3.fromRGB(60, 40, 40); br.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", br)
            
            tp.MouseButton1Click:Connect(function() root.CFrame = p.Character.HumanoidRootPart.CFrame * CFrame.new(0,0,3) end)
            br.MouseButton1Click:Connect(function() p.Character.HumanoidRootPart.CFrame = root.CFrame * CFrame.new(0,0,-3) end)
        end
    end
end

--// LOOPS
RunService.RenderStepped:Connect(function()
    -- Aimbot Inteligente
    if Vars.Aimbot and UIS:IsMouseButtonPressed(Vars.AimbotKey) then
        local t = GetClosestToMouse()
        if t then
            camera.CFrame = CFrame.new(camera.CFrame.Position, t.Position)
        end
    end
    
    -- Noclip
    if Vars.Fly or Vars.Noclip then
        Vars.Noclip = true
        for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false end end
    end
end)

-- Atalho Painel
UIS.InputBegan:Connect(function(i, g)
    if not g and i.KeyCode == Vars.PanelKey then Main.Visible = not Main.Visible end
end)

task.spawn(function() while true do UpdateList(); task.wait(5) end end)


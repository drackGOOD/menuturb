local ESPFolder = Instance.new("Folder")
ESPFolder.Name = "EliteESP"
ESPFolder.Parent = camera

local ESPObjects = {}
local Connections = {}

local function CreateESP(plr)
    if plr == player then return end

    local box = Drawing.new("Square")
    box.Thickness = 2.2
    box.Color = Color3.fromRGB(90, 170, 255)
    box.Filled = false
    box.Transparency = 0.95

    local name = Drawing.new("Text")
    name.Size = 17
    name.Color = Color3.fromRGB(255, 255, 255)
    name.Center = true
    name.Outline = true
    name.OutlineColor = Color3.new(0,0,0)

    local tracer = Drawing.new("Line")
    tracer.Thickness = 1.6
    tracer.Color = Color3.fromRGB(110, 190, 255)
    tracer.Transparency = 0.75

    -- Skeleton
    local skeletonLines = {}
    for i = 1, 6 do
        local line = Drawing.new("Line")
        line.Thickness = 1.4
        line.Color = Color3.fromRGB(100, 200, 255)
        line.Transparency = 0.8
        table.insert(skeletonLines, line)
    end

    ESPObjects[plr] = {
        Box = box,
        Name = name,
        Tracer = tracer,
        Skeleton = skeletonLines
    }

    Connections[plr] = RunService.RenderStepped:Connect(function()
        local character = plr.Character
        if not character or not character:FindFirstChild("HumanoidRootPart") or not character:FindFirstChild("Head") then
            box.Visible = false
            name.Visible = false
            tracer.Visible = false
            for _, l in ipairs(skeletonLines) do l.Visible = false end
            return
        end

        local rootPart = character.HumanoidRootPart
        local head = character.Head
        local humanoid = character:FindFirstChild("Humanoid")

        local rootPos, onScreen = camera:WorldToViewportPoint(rootPart.Position)
        if not onScreen then
            box.Visible = false
            name.Visible = false
            tracer.Visible = false
            for _, l in ipairs(skeletonLines) do l.Visible = false end
            return
        end

        local headPos = camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
        local legPos = camera:WorldToViewportPoint(rootPart.Position - Vector3.new(0, 3.2, 0))

        local height = (headPos.Y - legPos.Y) * 1.15
        local size = Vector2.new(height / 2.1, height)
        local pos = Vector2.new(rootPos.X - size.X/2, rootPos.Y - size.Y/1.9)

        -- Box ESP
        if Vars.BoxESP then
            box.Size = size
            box.Position = pos
            box.Visible = true
        else
            box.Visible = false
        end

        -- Name + Info
        if Vars.NameESP or Vars.DistanceESP or Vars.HealthESP then
            local dist = math.floor((root.Position - rootPart.Position).Magnitude)
            local text = plr.DisplayName
            if Vars.DistanceESP then text ..= "  [" .. dist .. "m]" end
            if Vars.HealthESP and humanoid then text ..= "  |  " .. math.floor(humanoid.Health) end

            name.Text = text
            name.Position = Vector2.new(rootPos.X, rootPos.Y - 38)
            name.Visible = true
        else
            name.Visible = false
        end

        -- Tracer
        if Vars.Tracers then
            tracer.From = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y - 30)
            tracer.To = Vector2.new(rootPos.X, rootPos.Y)
            tracer.Visible = true
        else
            tracer.Visible = false
        end

        -- Skeleton ESP (Melhorado)
        if Vars.SkeletonESP and character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso") then
            local function getPart(name) return character:FindFirstChild(name) end

            local torso = getPart("Torso") or getPart("UpperTorso")
            local larm = getPart("Left Arm") or getPart("LeftUpperArm")
            local rarm = getPart("Right Arm") or getPart("RightUpperArm")
            local lleg = getPart("Left Leg") or getPart("LeftLowerLeg")
            local rleg = getPart("Right Leg") or getPart("RightLowerLeg")

            if torso and head and larm and rarm and lleg and rleg then
                local p1 = camera:WorldToViewportPoint(head.Position)
                local p2 = camera:WorldToViewportPoint(torso.Position)
                local p3 = camera:WorldToViewportPoint(larm.Position)
                local p4 = camera:WorldToViewportPoint(rarm.Position)
                local p5 = camera:WorldToViewportPoint(lleg.Position)
                local p6 = camera:WorldToViewportPoint(rleg.Position)

                skeletonLines[1].From = Vector2.new(p1.X, p1.Y); skeletonLines[1].To = Vector2.new(p2.X, p2.Y) -- Head to Torso
                skeletonLines[2].From = Vector2.new(p2.X, p2.Y); skeletonLines[2].To = Vector2.new(p3.X, p3.Y) -- Torso to L Arm
                skeletonLines[3].From = Vector2.new(p2.X, p2.Y); skeletonLines[3].To = Vector2.new(p4.X, p4.Y) -- Torso to R Arm
                skeletonLines[4].From = Vector2.new(p2.X, p2.Y); skeletonLines[4].To = Vector2.new(p5.X, p5.Y) -- Torso to L Leg
                skeletonLines[5].From = Vector2.new(p2.X, p2.Y); skeletonLines[5].To = Vector2.new(p6.X, p6.Y) -- Torso to R Leg
                for _, line in ipairs(skeletonLines) do line.Visible = true end
            end
        else
            for _, l in ipairs(skeletonLines) do l.Visible = false end
        end
    end)
end


-- 1. VOO
local bv, bg
AddToggle("MODO VOO (TECLA V)", "Fly", function(s)
    if s then
        bv = Instance.new("BodyVelocity", root)
        bg = Instance.new("BodyGyro", root)
        bv.MaxForce = Vector3.new(1e6, 1e6, 1e6)

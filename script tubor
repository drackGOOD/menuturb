-- Função de Toggle Premium
local function CreateToggle(name, varName)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 0, 55)
    btn.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
    btn.Text = "  "..name
    btn.TextColor3 = Color3.fromRGB(210, 210, 210)
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.Font = Enum.Font.GothamSemibold
    btn.TextSize = 16
    btn.Parent = Container

    local btnCorner = Instance.new("UICorner", btn)
    btnCorner.CornerRadius = UDim.new(0, 14)

    local ind = Instance.new("Frame")
    ind.Size = UDim2.new(0, 22, 0, 22)
    ind.Position = UDim2.new(1, -35, 0.5, -11)
    ind.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
    ind.Parent = btn

    Instance.new("UICorner", ind).CornerRadius = UDim.new(1,0)

    btn.MouseButton1Click:Connect(function()
        Vars[varName] = not Vars[varName]
        local active = Vars[varName]

        TweenService:Create(btn, TweenInfo.new(0.3, Enum.EasingStyle.Quint), {
            BackgroundColor3 = active and Color3.fromRGB(45, 75, 180) or Color3.fromRGB(25, 25, 35)
        }):Play()

        TweenService:Create(ind, TweenInfo.new(0.3), {
            BackgroundColor3 = active and Color3.fromRGB(80, 220, 120) or Color3.fromRGB(50, 50, 60)
        }):Play()
    end)
end

-- ====================== ESP SYSTEM (CORRIGIDO E MELHORADO) ======================
local ESPFolder = Instance.new("Folder")
ESPFolder.Name = "EliteESP"
ESPFolder.Parent = camera

local Connections = {}
local ESPObjects = {}

local function CreateESP(plr)
    if plr == player then return end
    
    local box = Drawing.new("Square")
    box.Thickness = 2
    box.Color = Color3.fromRGB(80, 180, 255)
    box.Filled = false
    box.Transparency = 1
    
    local name = Drawing.new("Text")
    name.Size = 16
    name.Color = Color3.fromRGB(255,255,255)
    name.Center = true
    name.Outline = true
    
    local tracer = Drawing.new("Line")
    tracer.Thickness = 1.5
    tracer.Color = Color3.fromRGB(100, 200, 255)
    tracer.Transparency = 0.7
    
    ESPObjects[plr] = {Box = box, Name = name, Tracer = tracer}
    
    Connections[plr] = RunService.RenderStepped:Connect(function()
        if not Vars.BoxESP and not Vars.NameESP and not Vars.Tracers then return end
        
        local character = plr.Character
        if not character or not character:FindFirstChild("HumanoidRootPart") or not character:FindFirstChild("Head") then
            box.Visible = false
            name.Visible = false
            tracer.Visible = false
            return
        end
        
        local rootPart = character.HumanoidRootPart
        local head = character.Head
        local humanoid = character:FindFirstChild("Humanoid")
        
        local rootPos, onScreen = camera:WorldToViewportPoint(rootPart.Position)
        if not onScreen then
            box.Visible = false
            name.Visible = false
            tracer.Visible = false
            return
        end
        
        local headPos = camera:WorldToViewportPoint(head.Position)
        local legPos = camera:WorldToViewportPoint(rootPart.Position - Vector3.new(0,3,0))
        
        local size = Vector2.new(2000 / rootPos.Z, (headPos.Y - legPos.Y) * 1.1)
        local pos = Vector2.new(rootPos.X - size.X/2, rootPos.Y - size.Y/2)
        
        -- Box
        if Vars.BoxESP then
            box.Size = size
            box.Position = pos
            box.Visible = true
        else
            box.Visible = false
        end
        
        -- Name + Distance + Health
        if Vars.NameESP or Vars.DistanceESP or Vars.HealthESP then
            local dist = math.floor((player.Character.HumanoidRootPart.Position - rootPart.Position).Magnitude)
            local text = plr.DisplayName
            if Vars.DistanceESP then text = text .. " ["..dist.."m]" end
            if Vars.HealthESP and humanoid then text = text .. " | "..math.floor(humanoid.Health) end
            
            name.Text = text
            name.Position = Vector2.new(rootPos.X, rootPos.Y - 30)
            name.Visible = true
        else
            name.Visible = false
        end
        
        -- Tracer
        if Vars.Tracers then
            tracer.From = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y)
            tracer.To = Vector2.new(rootPos.X, rootPos.Y)
            tracer.Visible = true
        else
            tracer.Visible = false
        end
    end)
end


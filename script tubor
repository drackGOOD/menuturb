        Btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        task.wait(0.08)
        Btn.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
    end)
end

-- ====================== ESP PROFISSIONAL ======================
local ESPObjects = {}
local Connections = {}

local function CreateESP(plr)
    if plr == player then return end

    local box = Drawing.new("Square")
    box.Thickness = 2.2
    box.Color = Color3.fromRGB(0, 170, 255)
    box.Filled = false
    box.Transparency = 1

    local name = Drawing.new("Text")
    name.Size = 16
    name.Color = Color3.fromRGB(255, 255, 255)
    name.Center = true
    name.Outline = true

    local tracer = Drawing.new("Line")
    tracer.Thickness = 1.6
    tracer.Color = Color3.fromRGB(0, 200, 255)
    tracer.Transparency = 0.75

    local skeleton = {}
    for i = 1, 6 do
        local line = Drawing.new("Line")
        line.Thickness = 1.5
        line.Color = Color3.fromRGB(0, 180, 255)
        line.Transparency = 0.8
        table.insert(skeleton, line)
    end

    ESPObjects[plr] = {Box = box, Name = name, Tracer = tracer, Skeleton = skeleton}

    Connections[plr] = RunService.RenderStepped:Connect(function()
        local character = plr.Character
        if not character or not character:FindFirstChild("HumanoidRootPart") or not character:FindFirstChild("Head") then
            box.Visible = false
            name.Visible = false
            tracer.Visible = false
            for _, l in ipairs(skeleton) do l.Visible = false end
            return
        end

        local rootPart = character.HumanoidRootPart
        local head = character.Head
        local humanoid = character:FindFirstChild("Humanoid")

        local rootPos, onScreen = camera:WorldToViewportPoint(rootPart.Position)
        if not onScreen then
            box.Visible = false; name.Visible = false; tracer.Visible = false
            for _, l in ipairs(skeleton) do l.Visible = false end
            return
        end

        local headPos = camera:WorldToViewportPoint(head.Position)
        local legPos = camera:WorldToViewportPoint(rootPart.Position - Vector3.new(0, 3.4, 0))

        local height = (headPos.Y - legPos.Y) * 1.18
        local size = Vector2.new(height * 0.52, height)
        local pos = Vector2.new(rootPos.X - size.X/2, rootPos.Y - height * 0.48)

        -- Box ESP
        if Vars.BoxESP then
            box.Size = size
            box.Position = pos
            box.Visible = true
        else
            box.Visible = false
        end

        -- Name + Info
        if Vars.NameESP or Vars.DistanceESP or Vars.HealthESP then
            local dist = math.floor((root.Position - rootPart.Position).Magnitude)
            local text = plr.DisplayName
            if Vars.DistanceESP then text = text .. " [" .. dist .. "m]" end
            if Vars.HealthESP and humanoid then text = text .. " | " .. math.floor(humanoid.Health) end
            name.Text = text
            name.Position = Vector2.new(rootPos.X, rootPos.Y - 40)
            name.Visible = true
        else
            name.Visible = false
        end

        -- Tracer
        if Vars.Tracers then
            tracer.From = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y - 50)
            tracer.To = Vector2.new(rootPos.X, rootPos.Y)
            tracer.Visible = true
        else
            tracer.Visible = false
        end

        -- Skeleton (simplificado mas funcional)
        if Vars.SkeletonESP then
            local torso = character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso")
            if torso then
                local p1 = camera:WorldToViewportPoint(head.Position)
                local p2 = camera:WorldToViewportPoint(torso.Position)
                skeleton[1].From = Vector2.new(p1.X, p1.Y)
                skeleton[1].To = Vector2.new(p2.X, p2.Y)
                skeleton[1].Visible = true
            end
        else
            for _, l in ipairs(skeleton) do l.Visible = false end
        end
    end)
end

for _, plr in ipairs(Players:GetPlayers()) do CreateESP(plr) end

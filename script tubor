-- ====================== TOGGLE PREMIUM GLASS ======================
local function CreateToggle(name, varName)
    local ToggleFrame = Instance.new("TextButton")
    ToggleFrame.Size = UDim2.new(1, 0, 0, 58)
    ToggleFrame.BackgroundColor3 = Color3.fromRGB(28, 28, 42)
    ToggleFrame.BackgroundTransparency = 0.4
    ToggleFrame.Text = "   " .. name
    ToggleFrame.TextColor3 = Color3.fromRGB(225, 225, 225)
    ToggleFrame.TextXAlignment = Enum.TextXAlignment.Left
    ToggleFrame.Font = Enum.Font.GothamSemibold
    ToggleFrame.TextSize = 16
    ToggleFrame.Parent = Container

    local ToggleCorner = Instance.new("UICorner", ToggleFrame)
    ToggleCorner.CornerRadius = UDim.new(0, 16)

    local ToggleStroke = Instance.new("UIStroke", ToggleFrame)
    ToggleStroke.Color = Color3.fromRGB(80, 100, 200)
    ToggleStroke.Thickness = 1.2
    ToggleStroke.Transparency = 0.6

    -- Indicador circular com glow
    local Indicator = Instance.new("Frame")
    Indicator.Size = UDim2.new(0, 26, 0, 26)
    Indicator.Position = UDim2.new(1, -38, 0.5, -13)
    Indicator.BackgroundColor3 = Color3.fromRGB(55, 55, 70)
    Indicator.Parent = ToggleFrame

    local IndCorner = Instance.new("UICorner", Indicator)
    IndCorner.CornerRadius = UDim.new(1, 0)

    local IndStroke = Instance.new("UIStroke", Indicator)
    IndStroke.Color = Color3.fromRGB(100, 200, 140)
    IndStroke.Thickness = 2

    ToggleFrame.MouseButton1Click:Connect(function()
        Vars[varName] = not Vars[varName]
        local active = Vars[varName]

        TweenService:Create(ToggleFrame, TweenInfo.new(0.35, Enum.EasingStyle.Quint), {
            BackgroundColor3 = active and Color3.fromRGB(40, 65, 160) or Color3.fromRGB(28, 28, 42),
            BackgroundTransparency = active and 0.25 or 0.4
        }):Play()

        TweenService:Create(Indicator, TweenInfo.new(0.35, Enum.EasingStyle.Quint), {
            BackgroundColor3 = active and Color3.fromRGB(80, 220, 130) or Color3.fromRGB(55, 55, 70)
        }):Play()
    end)
end


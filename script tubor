-- Toggle estilo GTA V
local function CreateToggle(name, varName)
    local Button = Instance.new("TextButton")
    Button.Size = UDim2.new(1, -10, 0, 42)
    Button.BackgroundColor3 = Color3.fromRGB(25, 25, 28)
    Button.BorderSizePixel = 0
    Button.Text = "   " .. name
    Button.TextColor3 = Color3.fromRGB(235, 235, 235)
    Button.TextXAlignment = Enum.TextXAlignment.Left
    Button.Font = Enum.Font.GothamSemibold
    Button.TextSize = 17
    Button.AutoButtonColor = false
    Button.Parent = Container

    local BtnCorner = Instance.new("UICorner", Button)
    BtnCorner.CornerRadius = UDim.new(0, 4)

    local Indicator = Instance.new("Frame")
    Indicator.Size = UDim2.new(0, 6, 0, 28)
    Indicator.Position = UDim2.new(1, -18, 0.5, -14)
    Indicator.BackgroundColor3 = Color3.fromRGB(200, 60, 60) -- Vermelho = OFF
    Indicator.BorderSizePixel = 0
    Indicator.Parent = Button

    local IndCorner = Instance.new("UICorner", Indicator)
    IndCorner.CornerRadius = UDim.new(0, 3)

    local active = false

    Button.MouseButton1Click:Connect(function()
        active = not active
        Vars[varName] = active

        -- Animação suave
        TweenService:Create(Indicator, TweenInfo.new(0.25, Enum.EasingStyle.Quad), {
            BackgroundColor3 = active and Color3.fromRGB(80, 220, 80) or Color3.fromRGB(200, 60, 60)
        }):Play()

        -- Efeito de clique estilo GTA
        Button.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
        task.wait(0.08)
        Button.BackgroundColor3 = Color3.fromRGB(25, 25, 28)
    end)
end

-- ====================== ESP (Melhorado) ======================
local ESPObjects = {}
local Connections = {}

local function CreateESP(plr)
    if plr == player then return end

    local box = Drawing.new("Square")
    box.Thickness = 2
    box.Color = Color3.fromRGB(0, 180, 255)
    box.Filled = false
    box.Transparency = 1

    local name = Drawing.new("Text")
    name.Size = 16
    name.Color = Color3.fromRGB(255, 255, 255)
    name.Center = true
    name.Outline = true

    local tracer = Drawing.new("Line")
    tracer.Thickness = 1.6
    tracer.Color = Color3.fromRGB(0, 160, 255)
    tracer.Transparency = 0.75

    ESPObjects[plr] = {Box = box, Name = name, Tracer = tracer}

    Connections[plr] = RunService.RenderStepped:Connect(function()
        local character = plr.Character
        if not character or not character:FindFirstChild("HumanoidRootPart") then
            box.Visible = false
            name.Visible = false
            tracer.Visible = false
            return
        end

        local rootPart = character.HumanoidRootPart
        local head = character:FindFirstChild("Head")
        if not head then return end

        local rootPos, onScreen = camera:WorldToViewportPoint(rootPart.Position)
        if not onScreen then
            box.Visible = false
            name.Visible = false
            tracer.Visible = false
            return
        end

        local headPos = camera:WorldToViewportPoint(head.Position)
        local legPos = camera:WorldToViewportPoint(rootPart.Position - Vector3.new(0, 3.5, 0))

        local height = (headPos.Y - legPos.Y) * 1.18
        local size = Vector2.new(height * 0.52, height)
        local pos = Vector2.new(rootPos.X - size.X/2, rootPos.Y - height * 0.48)

        if Vars.BoxESP then
            box.Size = size
            box.Position = pos
            box.Visible = true
        else
            box.Visible = false
        end

        if Vars.NameESP or Vars.DistanceESP or Vars.HealthESP then
            local dist = math.floor((root.Position - rootPart.Position).Magnitude)
            local text = plr.DisplayName
            if Vars.DistanceESP then text ..= " [" .. dist .. "m]" end
            if Vars.HealthESP and character:FindFirstChild("Humanoid") then
                text ..= " | " .. math.floor(character.Humanoid.Health)
            end
            name.Text = text
            name.Position = Vector2.new(rootPos.X, rootPos.Y - 40)
            name.Visible = true
        else
            name.Visible = false
        end

        if Vars.Tracers then
            tracer.From = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y - 50)
            tracer.To = Vector2.new(rootPos.X, rootPos.Y)
            tracer.Visible = true
        else
            tracer.Visible = false
        end
    end)
end

for _, plr in ipairs(Players:GetPlayers()) do CreateESP(plr) end
Players.PlayerAdded:Connect(CreateESP)


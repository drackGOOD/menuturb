-- Aimbot Suave
RunService.RenderStepped:Connect(function()
    if Vars.Aimbot and UIS:IsMouseButtonPressed(Vars.AimbotKey) then
        local closest = nil
        local minDist = Vars.AimbotFOV

        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild("Head") then
                local head = p.Character.Head
                local pos, onScreen = camera:WorldToViewportPoint(head.Position)
                if onScreen then
                    local screenPos = Vector2.new(pos.X, pos.Y)
                    local mousePos = Vector2.new(mouse.X, mouse.Y)
                    local dist = (screenPos - mousePos).Magnitude

                    if dist < minDist then
                        minDist = dist
                        closest = head
                    end
                end
            end
        end

        if closest then
            local currentCFrame = camera.CFrame
            local targetCFrame = CFrame.lookAt(currentCFrame.Position, closest.Position)
            camera.CFrame = currentCFrame:Lerp(targetCFrame, Vars.AimbotSmoothness)
        end
    end
end)

-- Fly + Noclip (Melhorado)
local bodyVelocity, bodyGyro = nil, nil

RunService.Stepped:Connect(function()
    if Vars.Fly and root then
        if not bodyVelocity then
            bodyVelocity = Instance.new("BodyVelocity")
            bodyVelocity.MaxForce = Vector3.new(1e5, 1e5, 1e5)
            bodyVelocity.Parent = root

            bodyGyro = Instance.new("BodyGyro")
            bodyGyro.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
            bodyGyro.Parent = root
        end

        local moveDir = Vector3.new()
        if UIS:IsKeyDown(Enum.KeyCode.W) then moveDir += camera.CFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.S) then moveDir -= camera.CFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.A) then moveDir -= camera.CFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.D) then moveDir += camera.CFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.Space) then moveDir += Vector3.new(0,1,0) end
        if UIS:IsKeyDown(Enum.KeyCode.LeftControl) then moveDir -= Vector3.new(0,1,0) end

        bodyVelocity.Velocity = moveDir.Unit * 92
        bodyGyro.CFrame = camera.CFrame
    elseif bodyVelocity then
        bodyVelocity:Destroy()
        bodyGyro:Destroy()
        bodyVelocity, bodyGyro = nil, nil
    end

    -- Noclip
    if (Vars.Fly or Vars.Noclip) and char then
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end
end)


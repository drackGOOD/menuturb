-- Atalho do painel
UIS.InputBegan:Connect(function(i, gp)
    if gp then return end
    if i.KeyCode == Vars.PanelKey then
        Main.Visible = not Main.Visible
    elseif i.KeyCode == Vars.FlyKey then
        Vars.Fly = not Vars.Fly
        Vars.Noclip = Vars.Fly
    end
end)


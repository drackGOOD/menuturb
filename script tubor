-- ====================== LÓGICA DE FUNCIONAMENTO ======================

-- Speed Hack Estável
RunService.Heartbeat:Connect(function()
    pcall(function()
        if player.Character and player.Character:FindFirstChild("Humanoid") then
            if Vars.SpeedHack then
                player.Character.Humanoid.WalkSpeed = Vars.SpeedValue
            else
                player.Character.Humanoid.WalkSpeed = 16
            end
        end
    end)
end)

-- Fly & Noclip
local bodyVel, bodyGyro
RunService.Stepped:Connect(function()
    pcall(function()
        local char = player.Character
        if Vars.Fly and char and char:FindFirstChild("HumanoidRootPart") then
            if not bodyVel then
                bodyVel = Instance.new("BodyVelocity", char.HumanoidRootPart)
                bodyVel.MaxForce = Vector3.new(1e6, 1e6, 1e6)
                bodyGyro = Instance.new("BodyGyro", char.HumanoidRootPart)
                bodyGyro.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
            end
            
            local dir = Vector3.new()
            if UIS:IsKeyDown(Enum.KeyCode.W) then dir += camera.CFrame.LookVector end
            if UIS:IsKeyDown(Enum.KeyCode.S) then dir -= camera.CFrame.LookVector end
            if UIS:IsKeyDown(Enum.KeyCode.A) then dir -= camera.CFrame.RightVector end
            if UIS:IsKeyDown(Enum.KeyCode.D) then dir += camera.CFrame.RightVector end
            
            bodyVel.Velocity = dir * 100
            bodyGyro.CFrame = camera.CFrame
            
            for _, p in pairs(char:GetDescendants()) do
                if p:IsA("BasePart") then p.CanCollide = false end
            end
        else
            if bodyVel then bodyVel:Destroy() bodyVel = nil end
            if bodyGyro then bodyGyro:Destroy() bodyGyro = nil end
        end
    end)
end)

-- Teclas de Atalho
UIS.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == Enum.KeyCode.K then
        Main.Visible = not Main.Visible
    elseif input.KeyCode == Enum.KeyCode.V then
        Vars.Fly = not Vars.Fly
    end
end)

print("GTA V Style Menu Loaded! Press K to Toggle.")

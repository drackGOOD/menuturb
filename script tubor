-- Função de Criar Botão
local function CreateToggle(name, varName)
    local Btn = Instance.new("TextButton")
    Btn.Size = UDim2.new(1, -10, 0, 42)
    Btn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    Btn.BorderSizePixel = 0
    Btn.Text = "   " .. name
    Btn.TextColor3 = Color3.fromRGB(230, 230, 230)
    Btn.TextXAlignment = Enum.TextXAlignment.Left
    Btn.Font = Enum.Font.SourceSansSemibold
    Btn.TextSize = 17
    Btn.AutoButtonColor = false
    Btn.Parent = Container

    local Indicator = Instance.new("Frame")
    Indicator.Size = UDim2.new(0, 6, 0, 28)
    Indicator.Position = UDim2.new(1, -15, 0.5, -14)
    Indicator.BackgroundColor3 = Color3.fromRGB(200, 55, 55)
    Indicator.BorderSizePixel = 0
    Indicator.Parent = Btn

    Btn.MouseButton1Click:Connect(function()
        Vars[varName] = not Vars[varName]
        Indicator.BackgroundColor3 = Vars[varName] and Color3.fromRGB(55, 200, 55) or Color3.fromRGB(200, 55, 55)
    end)
end


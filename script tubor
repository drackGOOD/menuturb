--// LOOPS PRINCIPAIS
local move = {f=0, b=0, l=0, r=0, u=0, d=0}

RunService.Stepped:Connect(function()
    -- Noclip Real
    if Vars.Noclip and char then
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
    end
    
    -- God Mode
    if Vars.God and hum then hum.Health = hum.MaxHealth end
    
    -- Speed Hack
    if Vars.SpeedActive and hum then hum.WalkSpeed = 100 else if hum then hum.WalkSpeed = 16 end end

    -- Voo Estabilizado
    if Vars.Fly and root and bv and bg then
        bg.CFrame = camera.CFrame
        local dir = camera.CFrame.LookVector * (move.f + move.b) + camera.CFrame.RightVector * (move.l + move.r) + camera.CFrame.UpVector * (move.u + move.d)
        bv.Velocity = dir * Vars.Speed
    end
end)


--// FUNÇÃO DE CRIAR BOTÃO ELEGANTE
local function AddToggle(name, var, callback)
    local Btn = Instance.new("TextButton", Scroll)
    Btn.Size = UDim2.new(1, 0, 0, 40)
    Btn.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
    Btn.Text = "  " .. name
    Btn.TextColor3 = Color3.fromRGB(200, 200, 200)
    Btn.Font = Enum.Font.Gotham
    Btn.TextSize = 13
    Btn.TextXAlignment = Enum.TextXAlignment.Left
    
    local BCorner = Instance.new("UICorner", Btn)
    BCorner.CornerRadius = UDim.new(0, 8)

    local Status = Instance.new("Frame", Btn)
    Status.Size = UDim2.new(0, 10, 0, 10)
    Status.Position = UDim2.new(1, -25, 0.5, -5)
    Status.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
    Instance.new("UICorner", Status).CornerRadius = UDim.new(1, 0)

    Btn.MouseButton1Click:Connect(function()
        Vars[var] = not Vars[var]
        local active = Vars[var]
        
        -- Animação de cor
        TweenService:Create(Btn, TweenInfo.new(0.3), {BackgroundColor3 = active and Color3.fromRGB(40, 45, 60) or Color3.fromRGB(30, 30, 35)}):Play()
        TweenService:Create(Status, TweenInfo.new(0.3), {BackgroundColor3 = active and Color3.fromRGB(50, 255, 100) or Color3.fromRGB(255, 50, 50)}):Play()
        
        if callback then callback(active) end
    end)
end


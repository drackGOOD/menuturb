--// PRO MULTI-TOOL V2 (Otimizado)
local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local mouse = player:GetMouse()
local camera = workspace.CurrentCamera

-- CONFIGURAÇÕES
local state = {
    flying = false,
    speed = 70,
    god = false,
    esp = true,
    visible = true
}

-- REFERÊNCIAS DE PERSONAGEM
local char, humanoid, root
local function updateVars(newChar)
    char = newChar
    humanoid = char:WaitForChild("Humanoid")
    root = char:WaitForChild("HumanoidRootPart")
end
player.CharacterAdded:Connect(updateVars)
if player.Character then updateVars(player.Character) end

-- DESIGN DA UI (MAIS MODERNO)
local gui = Instance.new("ScreenGui", player.PlayerGui)
gui.ResetOnSpawn = false

local main = Instance.new("Frame", gui)
main.Size = UDim2.new(0, 220, 0, 380)
main.Position = UDim2.new(0, 30, 0.5, -190)
main.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
main.BorderSizePixel = 0

local corner = Instance.new("UICorner", main)
corner.CornerRadius = UDim.new(0, 8)

local title = Instance.new("TextLabel", main)
title.Size = UDim2.new(1, 0, 0, 40)
title.Text = "PREMIUM PANEL"
title.TextColor3 = Color3.new(1, 1, 1)
title.Font = Enum.Font.GothamBold
title.BackgroundTransparency = 1

local container = Instance.new("ScrollingFrame", main)
container.Size = UDim2.new(0.9, 0, 0.85, 0)
container.Position = UDim2.new(0.05, 0, 0.12, 0)
container.BackgroundTransparency = 1
container.ScrollBarThickness = 2

local layout = Instance.new("UIListLayout", container)
layout.Padding = UDim.new(0, 5)

-- FUNÇÃO PARA CRIAR BOTÕES ESTILIZADOS
local function createButton(name, callback)
    local btn = Instance.new("TextButton", container)
    btn.Size = UDim2.new(1, 0, 0, 35)
    btn.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
    btn.Text = name
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 12
    btn.AutoButtonColor = true
    
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
    btn.MouseButton1Click:Connect(callback)
    return btn
end

-- SISTEMA DE VOO
local bv = Instance.new("BodyVelocity")
local bg = Instance.new("BodyGyro")
bv.MaxForce = Vector3.new(1e6, 1e6, 1e6)
bg.MaxTorque = Vector3.new(1e6, 1e6, 1e6)

local ctrl = {f = 0, b = 0, l = 0, r = 0, q = 0, e = 0}

local flyBtn = createButton("Fly: OFF", function()
    state.flying = not state.flying
    if state.flying then
        bv.Parent = root
        bg.Parent = root
    else
        bv.Parent = nil
        bg.Parent = nil
    end
end)

-- SISTEMA ESP
local espData = {}
local function drawESP(p)
    if p == player then return end
    local box = Drawing.new("Square")
    box.Thickness = 1
    box.Filled = false
    box.Color = Color3.new(1, 0, 0)
    
    local name = Drawing.new("Text")
    name.Size = 14
    name.Center = true
    name.Outline = true
    name.Color = Color3.new(1, 1, 1)
    
    espData[p] = {box = box, name = name}
end

Players.PlayerAdded:Connect(drawESP)
Players.PlayerRemoving:Connect(function(p)
    if espData[p] then
        espData[p].box:Remove()
        espData[p].name:Remove()
        espData[p] = nil
    end
end)
for _, p in pairs(Players:GetPlayers()) do drawESP(p) end

-- TELEPORT LIST
local function refreshPlayerList()
    -- Limpar apenas botões de jogadores, não os de função
    for _, v in pairs(container:GetChildren()) do
        if v:IsA("TextButton") and not v.Name:find("Control") then
            v:Destroy()
        end
    end

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player then
            local pBtn = createButton("TP: " .. p.DisplayName, function()
                if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    root.CFrame = p.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3)
                end
            end)
            pBtn.BackgroundColor3 = Color3.fromRGB(35, 60, 45)
        end
    end
end

-- CONTROLES DE ENTRADA
UIS.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.W then ctrl.f = 1
    elseif input.KeyCode == Enum.KeyCode.S then ctrl.b = -1
    elseif input.KeyCode == Enum.KeyCode.A then ctrl.l = -1
    elseif input.KeyCode == Enum.KeyCode.D then ctrl.r = -1
    elseif input.KeyCode == Enum.KeyCode.E then ctrl.q = 1
    elseif input.KeyCode == Enum.KeyCode.Q then ctrl.e = -1
    elseif input.KeyCode == Enum.KeyCode.RightControl then
        main.Visible = not main.Visible
    end
end)

UIS.InputEnded:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.W then ctrl.f = 0
    elseif input.KeyCode == Enum.KeyCode.S then ctrl.b = 0
    elseif input.KeyCode == Enum.KeyCode.A then ctrl.l = 0
    elseif input.KeyCode == Enum.KeyCode.D then ctrl.r = 0
    elseif input.KeyCode == Enum.KeyCode.E then ctrl.q = 0
    elseif input.KeyCode == Enum.KeyCode.Q then ctrl.e = 0
    end
end)

-- CLICK TELEPORT (ALT + CLICK)
mouse.Button1Down:Connect(function()
    if UIS:IsKeyDown(Enum.KeyCode.LeftAlt) then
        root.CFrame = CFrame.new(mouse.Hit.Position + Vector3.new(0, 3, 0))
    end
end)

-- LOOP PRINCIPAL (RENDER STEPPED)
RunService.RenderStepped:Connect(function()
    flyBtn.Text = "Fly: " .. (state.flying and "ON" or "OFF")
    
    -- Lógica de Voo
    if state.flying and root then
        bg.CFrame = camera.CFrame
        local moveDir = camera.CFrame.LookVector * (ctrl.f + ctrl.b) + 
                        camera.CFrame.RightVector * (ctrl.l + ctrl.r) + 
                        camera.CFrame.UpVector * (ctrl.q + ctrl.e)
        
        if moveDir.Magnitude > 0 then
            bv.Velocity = moveDir.Unit * state.speed
        else
            bv.Velocity = Vector3.new(0, 0, 0)
        end
    end

    -- Lógica ESP Otimizada
    for p, draw in pairs(espData) do
        if state.esp and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = p.Character.HumanoidRootPart
            local pos, onScreen = camera:WorldToViewportPoint(hrp.Position)
            
            if onScreen then
                local dist = (camera.CFrame.Position - hrp.Position).Magnitude
                local size = 2000 / dist -- Escala baseada na distância
                
                draw.box.Size = Vector2.new(size, size * 1.5)
                draw.box.Position = Vector2.new(pos.X - size/2, pos.Y - size/1.5)
                draw.box.Visible = true
                
                draw.name.Text = string.format("%s [%dm]", p.Name, math.floor(dist))
                draw.name.Position = Vector2.new(pos.X, pos.Y + (size/2))
                draw.name.Visible = true
            else
                draw.box.Visible = false
                draw.name.Visible = false
            end
        else
            draw.box.Visible = false
            draw.name.Visible = false
        end
    end
end)

-- Atualiza lista de players a cada 5 segundos
task.spawn(function()
    while true do
        refreshPlayerList()
        task.wait(5)
    end
end)

local camera = workspace.CurrentCamera

--// CONFIGURAÇÕES GLOBAIS
local Vars = {
    Aimbot = false,
    Fly = false,
    Noclip = false,
    Autoclick = false,
    God = false,
    Speed = 100,
    PanelKey = Enum.KeyCode.K
}


-- ====================== FUNÇÕES DE UI (CRIAÇÃO DE BOTÕES) ======================
local function CreateToggle(text, varName)
    local Button = Instance.new("TextButton")
    Button.Size = UDim2.new(1, 0, 0, 50)
    Button.BackgroundColor3 = Color3.fromRGB(30, 30, 45)
    Button.AutoButtonColor = false
    Button.Text = "      " .. text
    Button.Font = Enum.Font.Gotham
    Button.TextColor3 = Color3.fromRGB(200, 200, 200)
    Button.TextSize = 15
    Button.TextXAlignment = Enum.TextXAlignment.Left
    Button.Parent = Content
    
    Instance.new("UICorner", Button).CornerRadius = UDim.new(0, 12)
    
    -- Indicador de On/Off
    local Indicator = Instance.new("Frame")
    Indicator.Size = UDim2.new(0, 10, 0, 24)
    Indicator.Position = UDim2.new(0, 8, 0.5, -12)
    Indicator.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
    Indicator.Parent = Button
    Instance.new("UICorner", Indicator).CornerRadius = UDim.new(0, 4)

    Button.MouseButton1Click:Connect(function()
        Vars[varName] = not Vars[varName]
        local active = Vars[varName]
        
        -- Animação Suave
        TweenService:Create(Indicator, TweenInfo.new(0.3), {
            BackgroundColor3 = active and Color3.fromRGB(100, 255, 150) or Color3.fromRGB(60, 60, 80)
        }):Play()
        
        TweenService:Create(Button, TweenInfo.new(0.3), {
            BackgroundColor3 = active and Color3.fromRGB(40, 40, 70) or Color3.fromRGB(30, 30, 45)
        }):Play()
    end)
end

